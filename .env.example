# Copy to .env locally. On Railway / Render, set these in the dashboard (never commit .env).

# CSFloat API (also accepted: CSFLOAT_API_KEY)
FLOAT_API_KEY=

# CSGO Empire (also accepted: EMPIRE_API_KEY)
CSGOEMPIRE_API_KEY=

# Pricempire search (optional — /api/search returns empty without it)
PRICEMPIRE_API_KEY=

# Steam (optional, if used by analysis paths)
STEAM_API_KEY=

# Local dev only — Railway/Render inject PORT automatically
# PORT=3001
