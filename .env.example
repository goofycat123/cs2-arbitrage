# Copy to .env locally. On Railway, set these in Variables (never commit .env).

# --- Access (use on production) ---
# Shared password for you + friends. Browser login; secret stays on server (HttpOnly cookie).
# Leave empty = no login (fine for local dev only).
APP_ACCESS_PASSWORD=

# Optional: cookie signing key (32+ random chars). If unset, derived from APP_ACCESS_PASSWORD.
# SESSION_SECRET=

# On Railway (HTTPS): set to 1 so the session cookie is Secure
# COOKIE_SECURE=1

# --- Upstream APIs ---
FLOAT_API_KEY=
CSGOEMPIRE_API_KEY=
PRICEMPIRE_API_KEY=
STEAM_API_KEY=
